{
  "name": "CDD DEVLOG",
  "version": "2.2.0",
  "private": true,
  "homepage": "https://blog.cdd.co.kr/",
  "scripts": {
    "start": "next dev",
    "dev": "next dev --webpack",
    "build": "next build --webpack && node ./scripts/postbuild.mjs",
    "serve": "python3 -m http.server 3000 -d out",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "blog": "node scripts/blog.mjs",
    "image:paste": "node scripts/blog.mjs paste",
    "image:migrate": "node scripts/migrate-content-images.mjs",
    "lint": "eslint --fix app components layouts scripts articles",
    "typecheck": "next typegen && tsc --noEmit",
    "prepare": "husky",
    "deploy": "gh-pages -d out --dotfiles --nojekyll"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@headlessui/react": "2.2.9",
    "@next/bundle-analyzer": "16.2.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.27",
    "contentlayer2": "0.5.8",
    "esbuild": "0.27.4",
    "gh-pages": "^6.3.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "hast-util-from-html-isomorphic": "^2.0.0",
    "image-size": "2.0.2",
    "next": "16.2.1",
    "next-contentlayer2": "0.5.8",
    "next-themes": "^0.4.6",
    "pliny": "0.4.1",
    "postcss": "^8.5.8",
    "pretendard": "^1.3.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-citation": "^2.3.2",
    "rehype-katex": "^7.0.1",
    "rehype-preset-minify": "7.0.1",
    "rehype-prism-plus": "^2.0.2",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-math": "^6.0.0",
    "tailwindcss": "^3.4.17",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@types/mdx": "^2.0.13",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "cross-env": "^10.1.0",
    "enquirer": "^2.4.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.30.1"
}
